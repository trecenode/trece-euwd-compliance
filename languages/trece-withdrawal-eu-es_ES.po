msgstr "Nombre de la empresa, dirección y datos de contacto para el formulario de desistimiento"

#: includes/admin/class-settings.php
msgid "Enable checkout consents"
msgstr "Activar consentimientos en el pago"

#: includes/admin/class-settings.php
msgid "Show consent checkboxes for digital content and services at checkout"
msgstr "Mostrar casillas de consentimiento para contenido digital y servicios en el pago"

#: includes/admin/class-settings.php
msgid "Digital content consent text"
msgstr "Texto de consentimiento de contenido digital"

#: includes/admin/class-settings.php
msgid "I expressly consent to the provision of digital content and acknowledge that I lose my right of withdrawal."
msgstr "Consiento expresamente el suministro de contenido digital y reconozco que pierdo mi derecho de desistimiento."

#: includes/admin/class-settings.php
msgid "Service consent text"
msgstr "Texto de consentimiento de servicio"

#: includes/admin/class-settings.php
msgid "I expressly request that the service begins before the withdrawal period expires and acknowledge that I will lose my right of withdrawal once the service has been fully performed."
msgstr "Solicito expresamente que el servicio comience antes de que expire el plazo de desistimiento y reconozco que perderé mi derecho de desistimiento una vez que el servicio haya sido completamente ejecutado."

#: includes/admin/class-settings.php
msgid "Enable product exclusions"
msgstr "Activar exclusiones de productos"

#: includes/admin/class-settings.php
msgid "Show exclusion notices on excluded product pages"
msgstr "Mostrar avisos de exclusión en las páginas de productos excluidos"

#: includes/admin/class-settings.php
msgid "Excluded categories"
msgstr "Categorías excluidas"

#: includes/admin/class-settings.php
msgid "Select product categories excluded from the right of withdrawal"
msgstr "Seleccione las categorías de productos excluidas del derecho de desistimiento"

